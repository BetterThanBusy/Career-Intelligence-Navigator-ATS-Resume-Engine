# Career Intelligence Navigator — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ─────────────────────────────────────────
# AI APIs
# ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/career_intelligence

# ─────────────────────────────────────────
# AUTH (Clerk)
# ─────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev

# ─────────────────────────────────────────
# PAYMENTS (Stripe)
# ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAMS_PRICE_ID=price_...

# ─────────────────────────────────────────
# EMAIL (Resend)
# ─────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=hello@betterthanbusy.com

# ─────────────────────────────────────────
# APP CONFIG
# ─────────────────────────────────────────
APP_ENV=development          # development | production
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=INFO

# ─────────────────────────────────────────
# CLOUDFLARE R2 (PDF storage)
# ─────────────────────────────────────────
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=career-intelligence-uploads
